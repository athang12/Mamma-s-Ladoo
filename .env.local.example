# Supabase Configuration (New Format)
# Replace these with your actual Supabase project credentials
# Get them from: https://app.supabase.com/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=your-project-url-here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key-here

# Example (replace with YOUR actual values):
# NEXT_PUBLIC_SUPABASE_URL=https://zvjieppjwztnjkifybmy.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxxxx...

# UPI SMS Payment Configuration (NEW - Works with Personal Savings Account!)
# Your UPI ID that customers will pay to
NEXT_PUBLIC_UPI_ID=yourname@paytm

# Your business/personal name shown to customers
NEXT_PUBLIC_MERCHANT_NAME=Custom Acrylic Store

# PhonePe Payment Gateway Configuration (Optional - Requires Business Account)
# Get these from: https://business.phonepe.com/

PHONEPE_MERCHANT_ID=your-merchant-id-here
PHONEPE_SALT_KEY=your-salt-key-here
PHONEPE_SALT_INDEX=1

# Set to 'production' for live payments, leave blank or 'sandbox' for testing
PHONEPE_ENV=sandbox

# Your application URL (needed for payment callbacks and redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# For Testing (Sandbox) - Use these credentials:
# PHONEPE_MERCHANT_ID=PGTESTPAYUAT
# PHONEPE_SALT_KEY=099eb0cd-02cf-4e2a-8aca-3e6c6aff0399
# PHONEPE_SALT_INDEX=1
# PHONEPE_ENV=sandbox

# For Production:
# PHONEPE_MERCHANT_ID=M1234567890
# PHONEPE_SALT_KEY=your-production-salt-key
# PHONEPE_SALT_INDEX=1
# PHONEPE_ENV=production
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
